{
  "extends": ["tslint:recommended", "tslint-react", "tslint-config-prettier"],
  "defaultSeverity": "warning",
  "rules": {
    "jsx-no-lambda": false, // 为 false 是允许使用箭头函数
    "ordered-imports": false // 为 true 指在导入模块时，必须按照字母顺序导入
  },
  "linterOptions": {
    "exclude": [
      "config/**/*.js",
      "node_modules/**/*.ts",
      "coverage/lcov-report/*.js"
    ]
  }
}
